{
  "manifest_version": 3,
  "name": "NTT Canvas Editor Dev",
  "version": "0.8.5",
  "description": "Local development version of the NTT Canvas Editor.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NTT Canvas Editor"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://ntt.instructure.com/*",
    "https://ntt.beta.instructure.com/*",
    "https://studentsecpi.sharepoint.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://ntt.instructure.com/courses/*/pages/*",
        "https://ntt.beta.instructure.com/courses/*/pages/*"
      ],
      "exclude_matches": [
        "https://ntt.instructure.com/courses/*/pages/*/edit*",
        "https://ntt.beta.instructure.com/courses/*/pages/*/edit*"
      ],
      "js": ["runtime.js"],
      "css": ["runtime.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://ntt.instructure.com/courses/*/pages/*/edit*",
        "https://ntt.beta.instructure.com/courses/*/pages/*/edit*"
      ],
      "js": ["runtime.js", "authoring.js"],
      "css": ["runtime.css", "authoring.css"],
      "run_at": "document_idle"
    }
  ]
}
